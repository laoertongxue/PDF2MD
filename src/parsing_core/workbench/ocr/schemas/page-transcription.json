{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Vision Page Transcription",
  "type": "object",
  "additionalProperties": false,
  "required": ["page", "blocks", "uncertain_items", "reading_order"],
  "properties": {
    "page": { "$ref": "#/$defs/page" },
    "blocks": {
      "type": "array",
      "maxItems": 512,
      "items": { "$ref": "#/$defs/block" }
    },
    "uncertain_items": {
      "type": "array",
      "maxItems": 512,
      "items": { "$ref": "#/$defs/uncertain_item" }
    },
    "reading_order": {
      "type": "array",
      "maxItems": 512,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    }
  },
  "$defs": {
    "finite_number": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "width", "height"],
      "properties": {
        "number": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "width": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "height": { "type": "integer", "minimum": 1, "maximum": 100000 }
      }
    },
    "bbox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "$ref": "#/$defs/finite_number" },
        "y": { "$ref": "#/$defs/finite_number" },
        "width": { "$ref": "#/$defs/finite_number" },
        "height": { "$ref": "#/$defs/finite_number" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "confidence"],
      "properties": {
        "text": { "type": "string", "maxLength": 4096 },
        "confidence": { "$ref": "#/$defs/finite_number" }
      }
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row", "column", "text", "confidence"],
      "properties": {
        "row": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "column": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "text": { "type": "string", "maxLength": 4096 },
        "confidence": { "$ref": "#/$defs/finite_number" },
        "region": { "$ref": "#/$defs/bbox" }
      }
    },
    "merged_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row", "column", "rowspan", "colspan"],
      "properties": {
        "row": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "column": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "rowspan": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "colspan": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    },
    "table": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["headers", "matrix", "cells", "merged_cells"],
      "properties": {
        "headers": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "maxLength": 4096 }
        },
        "matrix": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "array",
            "maxItems": 1000,
            "items": { "type": "string", "maxLength": 4096 }
          }
        },
        "cells": {
          "type": "array",
          "maxItems": 10000,
          "items": { "$ref": "#/$defs/cell" }
        },
        "merged_cells": {
          "type": "array",
          "maxItems": 10000,
          "items": { "$ref": "#/$defs/merged_cell" }
        }
      }
    },
    "formula": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["latex"],
      "properties": {
        "latex": { "type": "string", "maxLength": 8192 }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "text",
        "region",
        "bounding_box",
        "candidates",
        "uncertainty_reason",
        "reading_order",
        "table",
        "formula",
        "source_region",
        "confidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "type": {
          "type": "string",
          "enum": [
            "title",
            "heading",
            "paragraph",
            "footnote",
            "page_number",
            "table",
            "formula",
            "caption",
            "image",
            "list"
          ]
        },
        "text": { "type": "string", "maxLength": 8192 },
        "region": { "$ref": "#/$defs/bbox" },
        "bounding_box": { "$ref": "#/$defs/bbox" },
        "candidates": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/$defs/candidate" }
        },
        "uncertainty_reason": { "type": "string", "maxLength": 2048 },
        "reading_order": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "table": { "$ref": "#/$defs/table" },
        "formula": { "$ref": "#/$defs/formula" },
        "source_region": { "type": "string", "maxLength": 128 },
        "confidence": { "$ref": "#/$defs/finite_number" }
      }
    },
    "uncertain_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region", "reason", "candidates"],
      "properties": {
        "region": { "$ref": "#/$defs/bbox" },
        "reason": { "type": "string", "maxLength": 2048 },
        "candidates": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/$defs/candidate" }
        }
      }
    }
  }
}
