{
  "productName": "PDF2MD",
  "version": "0.1.2",
  "identifier": "com.pdf2md.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PDF2MD",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/python3",
      "binaries/vision-ocr"
    ],
    "resources": {
      "../../src": "src",
      "sidecar-runtime/python": "python-runtime"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
