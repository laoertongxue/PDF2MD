{
  "productName": "PDF2MD",
  "version": "0.1.0",
  "identifier": "com.pdf2md.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PDF2MD",
        "width": 520,
        "height": 480,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/python3"
    ],
    "resources": [
      "../../src"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
